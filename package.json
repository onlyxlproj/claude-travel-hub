{
  "name": "claude-travel-hub",
  "version": "1.0.0",
  "description": "A travel marketplace with tour booking, search, and Claude AI travel recommendations",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "next lint",
